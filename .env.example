ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
LOCAL_MOCK_MODE=false
SRD_RULES_VERSION=2024

# Auth (generate a strong random value for JWT_SECRET_KEY in production)
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database
# Local dev:
DATABASE_URL=sqlite+aiosqlite:///./campaign.db
# Production Supabase Postgres (direct URL):
# DATABASE_URL=postgresql+asyncpg://user:pass@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# CORS (comma-separated frontend origins)
CORS_ALLOW_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
# Supabase Syncing
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key

# Supabase Service Role Key (backend/admin only, never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-20250514
# MAX_SESSION_COST_USD=20.0
# MONTHLY_SPEND_CAP_USD=80.0
# MAP_PACK_VALIDATION_MODE=warn # off|warn|error
# LOCAL_MOCK_MODE=true   # Force local deterministic mock DM + voice, no API calls
# SRD_RULES_VERSION=2024 # Choose SRD dataset version for spells/features
# CORS_ALLOW_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,https://your-frontend.vercel.app
