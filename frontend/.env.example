# Copy this file to .env.local and set the URLs to match your backend port
VITE_API_URL=http://localhost:8010
VITE_WS_URL=ws://localhost:8010

# Production example:
# VITE_API_URL=https://your-backend.up.railway.app
# VITE_WS_URL=wss://your-backend.up.railway.app

# Supabase Auth (required for login/register):
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Supabase session APIs (optional, phase-by-phase migration):
# VITE_USE_SUPABASE_SESSIONS=true
